	"components": {
		"schemas": {
			"CommentCreate": {
				"properties": {
					"lesson_id": {
						"type": "integer",
						"exclusiveMinimum": 0.0,
						"title": "Lesson Id"
					},
					"content": {
						"type": "string",
						"maxLength": 1000,
						"minLength": 1,
						"title": "Content"
					},
					"parent_id": {
						"anyOf": [
							{ "type": "integer", "exclusiveMinimum": 0.0 },
							{ "type": "null" }
						],
						"title": "Parent Id"
					}
				},
				"type": "object",
				"required": ["lesson_id", "content"],
				"title": "CommentCreate"
			},
			"CourseCreate": {
				"properties": {
					"title": {
						"type": "string",
						"maxLength": 100,
						"minLength": 3,
						"title": "Title"
					},
					"description": {
						"type": "string",
						"maxLength": 2000,
						"title": "Description"
					}
				},
				"type": "object",
				"required": ["title", "description"],
				"title": "CourseCreate"
			},
			"DailyRewardResponse": {
				"properties": {
					"coins": { "type": "integer", "minimum": 0.0, "title": "Coins" },
					"xp": { "type": "integer", "minimum": 0.0, "title": "Xp" },
					"message": { "type": "string", "title": "Message" }
				},
				"type": "object",
				"required": ["coins", "xp", "message"],
				"title": "DailyRewardResponse"
			},
			"HTTPValidationError": {
				"properties": {
					"detail": {
						"items": { "$ref": "#/components/schemas/ValidationError" },
						"type": "array",
						"title": "Detail"
					}
				},
				"type": "object",
				"title": "HTTPValidationError"
			},
			"LessonCreate": {
				"properties": {
					"module_id": {
						"type": "integer",
						"exclusiveMinimum": 0.0,
						"title": "Module Id"
					},
					"title": {
						"type": "string",
						"maxLength": 100,
						"minLength": 3,
						"title": "Title"
					},
					"theory_content": {
						"type": "string",
						"maxLength": 10000,
						"minLength": 5,
						"title": "Theory Content"
					},
					"order": { "type": "integer", "minimum": 0.0, "title": "Order" }
				},
				"type": "object",
				"required": ["module_id", "title", "theory_content", "order"],
				"title": "LessonCreate"
			},
			"LoginRequest": {
				"properties": {
					"email": { "type": "string", "format": "email", "title": "Email" },
					"password": {
						"type": "string",
						"maxLength": 100,
						"minLength": 6,
						"title": "Password"
					}
				},
				"type": "object",
				"required": ["email", "password"],
				"title": "LoginRequest"
			},
			"ModuleCreate": {
				"properties": {
					"course_id": {
						"type": "integer",
						"exclusiveMinimum": 0.0,
						"title": "Course Id"
					},
					"title": {
						"type": "string",
						"maxLength": 100,
						"minLength": 3,
						"title": "Title"
					},
					"order": { "type": "integer", "minimum": 0.0, "title": "Order" }
				},
				"type": "object",
				"required": ["course_id", "title", "order"],
				"title": "ModuleCreate"
			},
			"ParentLinkRequest": {
				"properties": {
					"parent_email": {
						"type": "string",
						"format": "email",
						"title": "Parent Email"
					}
				},
				"type": "object",
				"required": ["parent_email"],
				"title": "ParentLinkRequest"
			},
			"RegisterRequest": {
				"properties": {
					"email": { "type": "string", "format": "email", "title": "Email" },
					"password": {
						"type": "string",
						"maxLength": 100,
						"minLength": 6,
						"title": "Password"
					},
					"nickname": {
						"type": "string",
						"maxLength": 30,
						"minLength": 2,
						"title": "Nickname"
					},
					"role": {
						"type": "string",
						"enum": ["student", "parent"],
						"title": "Role"
					}
				},
				"type": "object",
				"required": ["email", "password", "nickname", "role"],
				"title": "RegisterRequest"
			},
			"ReviewAttemptRequest": {
				"properties": {
					"is_correct": { "type": "boolean", "title": "Is Correct" }
				},
				"type": "object",
				"required": ["is_correct"],
				"title": "ReviewAttemptRequest"
			},
			"StartLessonRequest": {
				"properties": {
					"lesson_id": {
						"type": "integer",
						"exclusiveMinimum": 0.0,
						"title": "Lesson Id"
					}
				},
				"type": "object",
				"required": ["lesson_id"],
				"title": "StartLessonRequest"
			},
			"TaskCreate": {
				"properties": {
					"lesson_id": {
						"type": "integer",
						"exclusiveMinimum": 0.0,
						"title": "Lesson Id"
					},
					"type": {
						"type": "string",
						"enum": ["quiz", "input", "code"],
						"title": "Type"
					},
					"question": {
						"type": "string",
						"maxLength": 2000,
						"minLength": 5,
						"title": "Question"
					},
					"correct_answer": {
						"anyOf": [
							{ "type": "string", "maxLength": 5000 },
							{ "type": "null" }
						],
						"title": "Correct Answer"
					},
					"coins": { "type": "integer", "minimum": 0.0, "title": "Coins" }
				},
				"type": "object",
				"required": ["lesson_id", "type", "question", "coins"],
				"title": "TaskCreate"
			},
			"TaskSubmit": {
				"properties": {
					"answer": {
						"type": "string",
						"maxLength": 5000,
						"minLength": 1,
						"title": "Answer"
					}
				},
				"type": "object",
				"required": ["answer"],
				"title": "TaskSubmit"
			},
			"ValidationError": {
				"properties": {
					"loc": {
						"items": { "anyOf": [{ "type": "string" }, { "type": "integer" }] },
						"type": "array",
						"title": "Location"
					},
					"msg": { "type": "string", "title": "Message" },
					"type": { "type": "string", "title": "Error Type" },
					"input": { "title": "Input" },
					"ctx": { "type": "object", "title": "Context" }
				},
				"type": "object",
				"required": ["loc", "msg", "type"],
				"title": "ValidationError"
			}
		}
	}
}
